# Copy this to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=fraud_pass
POSTGRES_DB=fraud_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Fraud decision thresholds — these are business parameters, not model parameters.
# Tune them based on acceptable FP/FN trade-off for your use case.
THRESHOLD_APPROVE=0.3
THRESHOLD_DECLINE=0.7

# ── Paths ─────────────────────────────────────────────────────────────────────
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed
MODEL_PATH=models/champion
